    {
      "parameters": {
        "jsCode": "// แปลง image binary เป็น base64 data URL สำหรับ Mistral OCR (รองรับ binaryMode: separate)\nconst item = $input.first();\nconst binaryData = item.binary.image;\nconst mimeType = binaryData.mimeType || 'image/jpeg';\n\n// ใช้ helper เพื่อดึง buffer จริงจาก filesystem\nconst buffer = await this.helpers.getBinaryDataBuffer(0, 'image');\nconst base64 = buffer.toString('base64');\nconst dataUrl = `data:${mimeType};base64,${base64}`;\n\nreturn [{ json: { image_data_url: dataUrl } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5200,
        260
      ],
      "id": "c1d2e3f4-convert-image-base64",
