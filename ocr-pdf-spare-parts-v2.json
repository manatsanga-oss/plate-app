    {
      "parameters": {
        "jsCode": "// ดึง text จาก LLM\nconst raw = $json.text;\n\n// แปลง string → JSON\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  throw new Error(\"JSON parse ไม่ได้: \" + e.message);\n}\n\n// ดึง items ออกมา\nconst items = parsed.items || [];\n\n// แปลงให้ n8n ใช้ง่าย (แยกเป็นหลาย item)\nreturn items.map((it, index) => ({\n  json: {\n    line_no: index + 1,\n    product_code: it.product_code || \"\",\n    product_name: it.product_name || \"\",\n    qty: Number(it.qty) || 0\n  }\n}));"
      },
