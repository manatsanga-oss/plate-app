    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst issueNo = (body.issue_no || '').trim();\nconst items = Array.isArray(body.items) ? body.items : [];\nif (!issueNo) throw new Error('ไม่พบ issue_no');\nif (!items.length) throw new Error('ไม่มีรายการ');\nconst totalQty = items.reduce((s, i) => s + (Number(i.qty_issue) || 0), 0);\nreturn [{ json: { issue_no: issueNo, total_qty: totalQty, note: body.note || '', updated_by: body.updated_by || '', items } }];"
      },
