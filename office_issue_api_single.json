    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  p.product_id,\n  p.product_name,\n  p.unit,\n  COALESCE(s.qty_on_hand, 0) AS qty_on_hand\nFROM products p\nLEFT JOIN stock s ON s.product_id = p.product_id\nWHERE p.is_active = true\nORDER BY p.product_name ASC;",
        "options": {}
      },
      "id": "node-load-sql",
      "name": "SQL - Load Materials",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [600, 60],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": { "responseHeaders": { "entries": [{ "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
      "id": "node-respond-load",
      "name": "Respond - Load",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [840, 60]
    },

    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst now = new Date();\nconst yyyy = now.getFullYear();\nconst mm = String(now.getMonth() + 1).padStart(2, '0');\nconst dd = String(now.getDate()).padStart(2, '0');\nconst rand = String(Math.floor(Math.random() * 9000) + 1000);\nconst issueNo = `ISS-${yyyy}${mm}${dd}-${rand}`;\nconst items = Array.isArray(body.items) ? body.items : [];\nconst totalQty = items.reduce((s, i) => s + (Number(i.qty_issue) || 0), 0);\nreturn [{ json: {\n  issue_no: issueNo,\n  issue_date: `${yyyy}-${mm}-${dd}`,\n  requester_name: body.username || '',\n  issue_branch: body.branch || '',\n  total_qty: totalQty,\n  created_by: body.username || '',\n  items\n} }];"
      },
      "id": "node-save-prepare",
      "name": "Code - Prepare Save",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [600, 180]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO issue_header (issue_no, issue_date, requester_name, issue_branch, total_qty, created_by, created_at)\nVALUES (\n  '{{ $json.issue_no }}',\n  '{{ $json.issue_date }}',\n  '{{ $json.requester_name }}',\n  '{{ $json.issue_branch }}',\n  {{ $json.total_qty }},\n  '{{ $json.created_by }}',\n  NOW()\n);",
        "options": {}
      },
      "id": "node-save-header",
      "name": "SQL - Insert Header",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [840, 180],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const data = $('Code - Prepare Save').first().json;\nconst values = data.items.map((item, idx) =>\n  `('${data.issue_no}', ${item.line_no || idx + 1}, '${(item.product_id||'').replace(/'/g,\"''\")}', '${(item.product_name||'').replace(/'/g,\"''\")}', '${(item.unit||'').replace(/'/g,\"''\")}', ${Number(item.qty_issue)||0}, ${item.qty_on_hand!=null ? Number(item.qty_on_hand) : 'NULL'}, NOW())`\n).join(',\\n');\nreturn [{ json: { insertSql: values, issueNo: data.issue_no, items: data.items } }];"
      },
      "id": "node-save-items-code",
      "name": "Code - Prepare Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1080, 180]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO issue_items (issue_no, line_no, product_id, product_name, unit, qty_issue, qty_on_hand, created_at)\nVALUES\n{{ $json.insertSql }};",
        "options": {}
      },
      "id": "node-save-items-sql",
      "name": "SQL - Insert Items",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1320, 180],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE stock s\nSET qty_on_hand = s.qty_on_hand - i.qty_issue,\n    updated_at = NOW()\nFROM issue_items i\nWHERE i.issue_no = '{{ $('Code - Prepare Save').first().json.issue_no }}'\n  AND s.product_id = i.product_id;",
        "options": {}
      },
      "id": "node-save-stock",
      "name": "SQL - Update Stock",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [1560, 180],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIAL_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"success\": true, \"message\": \"บันทึกใบเบิกเรียบร้อย\", \"issue_no\": \"{{ $('Code - Prepare Save').first().json.issue_no }}\" }",
        "options": { "responseHeaders": { "entries": [{ "name": "Access-Control-Allow-Origin", "value": "*" }] } }
      },
      "id": "node-respond-save",
      "name": "Respond - Save",
