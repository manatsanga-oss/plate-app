    {
      "parameters": {
        "jsCode": "const headerRows = $('SQL - Open Header').all();\nconst itemRows = $('SQL - Open Items').all();\nconst header = headerRows.length > 0 ? headerRows[0].json : {};\nconst items = itemRows.map(r => r.json);\nreturn [{ json: { header, items } }];"
      },
